---
import { getCollection } from 'astro:content';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import FilterZone from '../components/custom/FilterZone.astro';

const projects = (await getCollection('work')).sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const allSoftware = [...new Set(projects.flatMap(p => p.data.software || []))];
const allTags = [...new Set(projects.flatMap(p => p.data.tags || []))];
const allTypes = [...new Set(projects.map(p => p.data.type))];

// We pass an empty array to FilterZone initially or handle it in the component
const activeFilters = [];
---

<BaseLayout
	title="Portfolio | Sebastián Jaovi"
	description="Learn about Sebastián Jaovi's best projects"
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Creative with tech"
				tagline="Explore my best films, apps and conferences"
				align="start"
			/>

			<FilterZone 
				availableSoftware={allSoftware} 
				availableTags={allTags} 
				availableTypes={allTypes} 
			/>

			<Grid variant="offset">
				{
					projects.map((project) => (
						<li 
							class="project-card" 
							data-type={project.data.type}
							data-tags={project.data.tags?.join(',')}
							data-software={project.data.software?.join(',')}
						>
							<PortfolioPreview project={project} />
						</li>
					))
				}
			</Grid>
		</main>
		<ContactCTA />
	</div>

</BaseLayout>

<script>
    function syncProjectVisibility() {
		const params = new URLSearchParams(window.location.search);
		const activeFilters = params.get('f')?.split(',').filter(Boolean) || [];
		const mode = params.get('m') || 'or'; // Default to OR
		const projectCards = document.querySelectorAll('.project-card');

		projectCards.forEach(card => {
			if (activeFilters.length === 0) {
				card.style.display = 'block';
				return;
			}

			const type = card.getAttribute('data-type');
			const tags = card.getAttribute('data-tags')?.split(',') || [];
			const software = card.getAttribute('data-software')?.split(',') || [];
			const itemData = [type, ...tags, ...software];

			// Logic Switch
			const matches = mode === 'or' 
				? activeFilters.some(f => itemData.includes(f)) 
				: activeFilters.every(f => itemData.includes(f));

			card.style.display = matches ? 'block' : 'none';
		});
	}

    // Listen for the custom event from our FilterZone
    window.addEventListener('filter-updated', syncProjectVisibility);
    window.addEventListener('popstate', syncProjectVisibility);
    syncProjectVisibility();
</script>