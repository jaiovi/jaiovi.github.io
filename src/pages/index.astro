---
import { getCollection } from 'astro:content';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

import FilterZone from '../components/custom/FilterZone.astro';

const projects = (await getCollection('work')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

// 1. Get unique tags and types for the "Source" zone
const allTags = [...new Set(projects.flatMap(p => p.data.tags))];
const allTypes = [...new Set(projects.map(p => p.data.type))];

// 2. Read filters from URL (e.g., ?f=React,Film)
const url = new URL(Astro.request.url);
const activeFilters = url.searchParams.get('f')?.split(',') || [];

// 3. Filter projects
const filteredProjects = activeFilters.length > 0 
    ? projects.filter(p => 
        activeFilters.includes(p.data.type) || 
        p.data.tags.some(t => activeFilters.includes(t))
      )
    : projects;
---

<BaseLayout
	title="Portfolio | Sebastián Jaovi"
	description="Learn about Sebastián Jaovi's best projects"
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Creative with tech"
				tagline="See my best films, apps and conferences"
				align="start"
			/>
			<Grid variant="offset">
				{
					projects.map((project) => (
						<li>
							<PortfolioPreview project={project} />
						</li>
					))
				}
			</Grid>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>
