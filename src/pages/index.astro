---
import { getCollection } from 'astro:content';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import FilterZone from '../components/custom/FilterZone.astro';

const projects = (await getCollection('work')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

// Unique lists for the FilterZone
const allSoftware = [...new Set(projects.flatMap(p => p.data.software || []))];
const allTags = [...new Set(projects.flatMap(p => p.data.tags || []))];
const allTypes = [...new Set(projects.map(p => p.data.type))];

// Get filters from the URL
// .filter(Boolean) is CRITICAL: it prevents empty strings from breaking the logic
const activeFilters = Astro.url.searchParams.get('f')?.split(',').filter(Boolean) || [];

// DEBUG: Check your terminal! If this prints [], the URL param isn't being read.
console.log('URL:', Astro.url.href);
console.log('searchParams:', Astro.url.searchParams.toString());
console.log('Active Filters:', activeFilters);

const filteredProjects = activeFilters.length > 0 
    ? projects.filter(p => {
        const hasType = activeFilters.includes(p.data.type);
        const hasTag = p.data.tags?.some(t => activeFilters.includes(t));
        const hasSoftware = p.data.software?.some(s => activeFilters.includes(s));
        return hasType || hasTag || hasSoftware;
      })
    : projects;
---

<BaseLayout
	title="Portfolio | Sebastián Jaovi"
	description="Learn about Sebastián Jaovi's best projects"
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Creative with tech"
				tagline="Explore my best films, apps and conferences"
				align="start"
			/>

			<FilterZone 
				availableSoftware={allSoftware} 
				availableTags={allTags} 
				availableTypes={allTypes} 
				activeFilters={activeFilters} 
			/>

			<Grid variant="offset">
				{
					/* TRIPLE CHECK: This MUST be filteredProjects. 
                       If it says 'projects', the UI will never change.
                    */
					filteredProjects.map((project) => (
						<li key={project.id}>
							<PortfolioPreview project={project} />
						</li>
					))
				}
			</Grid>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>