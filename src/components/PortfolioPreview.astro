---
import type { CollectionEntry } from 'astro:content';
import Pill from './Pill.astro';

import { Image } from 'astro:assets';

interface Props {
	project: CollectionEntry<'work'>;
}

//<img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" />
//<Image src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" width="100%" height="100%" />
const { data, id } = Astro.props.project;
---

<a class="card" href={`/work/${id}`} style={`view-transition-name: card-${id};`}>
	<span class="title">{data.title}
		<span class="types">- {data.type} </span>
	</span>
	<Image class="img" src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" width="480" height="360" />
	<span class="details">
		
		<div class="tags">
			{data.tags.map((t) => <Pill>{t}</Pill>)}
		</div>
	</span>
</a>

<style>
	.card {
		display: grid;
		grid-template: auto 1fr / auto 1fr;
		height: 15rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		font-family: var(--font-brand);
		font-size: var(--text-lg);
		font-weight: 800;
		transition: box-shadow var(--theme-transition);
	}

	.card:hover {
		box-shadow: var(--shadow-md);
	}

	.title {
		grid-area: 1 / 1 / 2 / 2;
		z-index: 1;
		margin: 0.25rem;
		padding: 0.25rem .25rem;
		background: var(--gray-999);
		color: var(--gray-200);
		border-radius: 0.375rem;
	}

	img {
		grid-area: 1 / 1 / 3 / 3;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.details {
		grid-area: 2 / 1 / 3 / 0;
		z-index: 2;
		display: flex;
		align-items: flex-start;
		gap: 0.25rem;
		margin: 0.5rem;
		padding: 0.1rem .1rem;
		color: var(--gray-200);
		border-radius: 0.375rem;
	}

	.types {
		font-size: var(--text-sm);
		color: var(--gray-500);
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.1rem;
	}

	@media (min-width: 50em) {
		.card {
			height: 20rem;
			border-radius: 1.5rem;
		}

		.title {
			border-radius: 1.5rem;
		}
	}
</style>