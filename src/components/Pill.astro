---
interface Props {
	variant?: 'type' | 'tag' | 'software' | 'active';
}

const { variant = 'tag' } = Astro.props;
---

<div class:list={['pill', variant]}>
	<slot />
</div>

<style>
	.pill {
		display: flex;
		padding: 0.25rem 1rem;
		gap: 0.25rem;
		color: var(--accent-text-over);
		border-radius: 999rem;
		font-size: var(--text-xs);
		line-height: 1.35;
		white-space: nowrap;
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	/* Color Variants */
	.type { background-color: #7611a6; } /* Purple-ish */
	.tag { background-color: var(--accent-regular); } /* Neutral */
	.software { background-color: #2e7d32; } /* Green-ish */
	.active { 
		background-color: var(--accent-light); 
		border: 1px solid var(--accent-light);
	}

	@media (min-width: 50em) {
		.pill { font-size: var(--text-sm); }
	}
</style>